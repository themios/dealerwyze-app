# DealerWyze — Environment Variables
# Copy this file to .env.local and fill in your values.
# Variables marked [REQUIRED] will crash the app on startup if missing.
# Variables marked [optional] enable specific features when set.

# ─── Supabase [REQUIRED] ──────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # bypasses RLS — keep secret

# ─── App URL [REQUIRED] ───────────────────────────────────────────────────────
# Must match exactly what's configured in Twilio console (no trailing slash)
NEXT_PUBLIC_APP_URL=https://dealerwyze.com

# ─── Auth / Session [REQUIRED] ────────────────────────────────────────────────
# 32+ random bytes — used to sign staff impersonation cookies
STAFF_SESSION_SECRET=generate-with-openssl-rand-hex-32

# ─── Upstash Redis [REQUIRED in production for distributed rate limiting] ──────
# Without these, rate limits fall back to in-process (not shared across instances).
# Create a database at upstash.com → copy REST URL and token.
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ─── Cron Authentication ──────────────────────────────────────────────────────
CRON_SECRET=your-cron-secret                       # Bearer token for cron routes
LEADS_POLL_SECRET=your-legacy-cron-secret          # Legacy fallback for older cron callers
CronjobAPI=your-cronjob-org-api-key                # cron-job.org management API key

# ─── Mode Flags ───────────────────────────────────────────────────────────────
SAAS_MODE=true                                     # Must be true in production
NEXT_PUBLIC_TWILIO_ENABLED=true                    # Set false to disable Twilio in dev
TWILIO_LEGACY_FALLBACK_ENABLED=true                # Keep true until all orgs migrated

# ─── Twilio [REQUIRED for messaging/voice] ───────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token           # Used for webhook HMAC validation
TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Stripe [REQUIRED for billing] ───────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...                    # From Stripe dashboard webhook settings
STRIPE_PRICE_ID=price_...                          # Tier 1 monthly price ID
STRIPE_PRICE_ID_TIER2=price_...                    # Tier 2 monthly price ID
STRIPE_PRICE_ID_STORAGE_10GB=price_...             # Storage add-on 10GB
STRIPE_PRICE_ID_STORAGE_25GB=price_...             # Storage add-on 25GB

# ─── AI / LLM ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...                       # Receipt OCR + voice summarizer
GROQ_API_KEY=gsk_...                               # Dealer Brief (fast inference)
GROQ_API_KEY_2=gsk_...                             # Fallback Groq key
PERPLEXITY_API_KEY=pplx-...                        # Market intelligence pricing

# ─── Retell AI (voice agent) ─────────────────────────────────────────────────
RETELL_API_KEY=your-retell-api-key
RETELL_WEBHOOK_SECRET=your-retell-webhook-secret   # HMAC-SHA256 webhook validation

# ─── VAPI (optional voice provider) ─────────────────────────────────────────
VAPI_WEBHOOK_SECRET=your-vapi-webhook-secret

# ─── Google / Gmail ───────────────────────────────────────────────────────────
GMAIL_CLIENT_ID=your-google-oauth-client-id
GMAIL_CLIENT_SECRET=your-google-oauth-client-secret
GMAIL_PUBSUB_TOPIC=projects/your-project/topics/gmail-push  # Gmail watch topic used by users.watch
GMAIL_PUBSUB_SERVICE_ACCOUNT_EMAIL=gmail-api-push@system.gserviceaccount.com  # Verify Google Pub/Sub push identity
GOOGLE_TTS_API_KEY=your-google-tts-api-key         # Text-to-speech for video narration

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_...

# ─── Telegram (optional — admin alerts) ──────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id
TELEGRAM_WEBHOOK_SECRET=your-telegram-webhook-secret
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=YourBotUsername

# ─── Market Intelligence ──────────────────────────────────────────────────────
MARKETCHECK_API_KEY=your-marketcheck-api-key       # Vehicle market data

# ─── Video / Remotion Lambda ──────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_REGION=us-east-1
REMOTION_SERVE_URL=https://remotionlambda-xxx.s3.amazonaws.com/sites/dealerwyze-vehicles/index.html
REMOTION_LAMBDA_FUNCTION_NAME=remotion-render-4-0-441-mem2048mb-disk2048mb-300sec
RENDER_WEBHOOK_SECRET=your-render-webhook-secret   # Remotion Lambda webhook HMAC

# ─── Cloudflare R2 (video storage) ───────────────────────────────────────────
R2_ACCOUNT_ID=your-r2-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_VIDEOS=dealerwyze-videos
R2_VIDEOS_PUBLIC_URL=https://videos.dealerwyze.com

# ─── Social Media OAuth ───────────────────────────────────────────────────────
SOCIAL_OAUTH_STATE_SECRET=your-oauth-state-secret  # Signs OAuth state params
META_APP_ID=your-meta-app-id                       # Facebook/Instagram
META_APP_SECRET=your-meta-app-secret
INSTAGRAM_APP_ID=your-instagram-app-id
INSTAGRAM_APP_SECRET=your-instagram-app-secret
YOUTUBE_CLIENT_ID=your-youtube-client-id
YOUTUBE_CLIENT_SECRET=your-youtube-client-secret
# TikTok — use sandbox keys for dev, production keys for prod
TIKTOK_CLIENT_KEY=your-tiktok-client-key
TIKTOK_CLIENT_SECRET=your-tiktok-client-secret

# ─── Multi-tenant identifiers ─────────────────────────────────────────────────
APOLLO_ORG_ID=your-apollo-auto-org-uuid            # Tim's test tenant org ID

# ─── Integrations ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_INTERVO_WIDGET_ID=your-intervo-widget-id  # Live chat widget on landing page
UNSUBSCRIBE_SECRET=generate-with-openssl-rand-hex-32  # Required. Signs unsubscribe links in emails.
PUBSUB_VERIFICATION_TOKEN=your-legacy-pubsub-token  # Transitional only for /api/integrations/gmail/push; remove after migrating to OIDC /api/gmail/webhook

# ─── Google Ads (optional — conversion tracking + remarketing) ───────────────
# Find these in Google Ads: Tools > Conversions > your conversion action > Tag setup
NEXT_PUBLIC_GOOGLE_ADS_ID=AW-XXXXXXXXXX              # Google Ads account tag (e.g. AW-123456789)
NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_LABEL=XXXXXXXXXXXX # Conversion action label (e.g. AbCdEfGhIjK)

# ─── Sentry (optional — error tracking) ──────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=https://xxx@sentry.io/xxx
SENTRY_AUTH_TOKEN=your-sentry-auth-token
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=your-sentry-project

# ─── Vercel (set automatically by Vercel, do not set manually) ───────────────
# VERCEL_OIDC_TOKEN — injected by Vercel runtime for OIDC verification
#In Google Ads: Tools > Conversions > create a "Sign up" conversion action → get your AW-XXXXXXXXXX tag ID and conversion label
#Add both to Vercel env vars: NEXT_PUBLIC_GOOGLE_ADS_ID and NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_LABEL
