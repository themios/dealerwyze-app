# ApolloCRM (apollo-crm) environment template
# Required values should be set for local, staging, and production.

############################################
# Supabase (required)
############################################
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

############################################
# Stripe (required for billing/webhooks)
############################################
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_BHPH_ACH_WEBHOOK_SECRET=

############################################
# Twilio (required for inbound/outbound SMS)
############################################
TWILIO_AUTH_TOKEN=
TWILIO_ACCOUNT_SID=
TWILIO_FROM_NUMBER=
TWILIO_LEGACY_FALLBACK_ENABLED=false

############################################
# Email (Resend) (required for notifications)
############################################
RESEND_API_KEY=
RESEND_FROM_DOMAIN=dealerwyze.com

############################################
# Platform ops (required)
############################################
PLATFORM_OWNER_EMAIL=support@dealerwyze.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

############################################
# Cron/Auth secrets (required in deployed envs)
############################################
CRON_SECRET=
LEADS_POLL_SECRET=
STAFF_SESSION_SECRET=

############################################
# Optional integrations
############################################
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
META_APP_ID=
META_APP_SECRET=
BRIDGE_API_BASE=https://api.bridgeinteractive.dev/
BRIDGE_SANDBOX_BASE_URL=https://api.bridgeinteractive.dev/
BRIDGE_API_KEY=
BRIDGE_API_SECRET=
BRIDGE_WEBHOOK_SECRET=
REPLIERS_API_KEY=
REPLIERS_API_BASE=https://api.repliers.io
REPLIERS_IMAGE_BASE=https://cdn.repliers.io/
# DealerWyze — Environment Variables
# Copy this file to .env.local and fill in your values.
# Variables marked [REQUIRED] will crash the app on startup if missing.
# Variables marked [optional] enable specific features when set.

# ─── Supabase [REQUIRED] ──────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # bypasses RLS — keep secret

# ─── App URL [REQUIRED] ───────────────────────────────────────────────────────
# Must match exactly what's configured in Twilio console (no trailing slash)
NEXT_PUBLIC_APP_URL=https://dealerwyze.com

# ─── Auth / Session [REQUIRED] ────────────────────────────────────────────────
# 32+ random bytes — used to sign staff impersonation cookies
STAFF_SESSION_SECRET=generate-with-openssl-rand-hex-32

# ─── Upstash Redis [REQUIRED in production for distributed rate limiting] ──────
# Upstash provides distributed rate limiting across all app instances.
# Optional in development (rate limits will be in-process only).
# Required in production — if missing, rate limits fail closed (return 429, not silent allow).
# CRITICAL: Both variables MUST be set together. Partial config (one set, one missing) will cause
# startup error in production and warn in development.
# Create a database at upstash.com → copy REST URL and token.
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ─── Cron Authentication ──────────────────────────────────────────────────────
CRON_SECRET=your-cron-secret                       # Bearer token for cron routes
LEADS_POLL_SECRET=your-legacy-cron-secret          # Legacy fallback for older cron callers
CronjobAPI=your-cronjob-org-api-key                # cron-job.org management API key

# ─── Mode Flags ───────────────────────────────────────────────────────────────
SAAS_MODE=true                                     # Must be true in production
NEXT_PUBLIC_TWILIO_ENABLED=true                    # Set false to disable Twilio in dev
TWILIO_LEGACY_FALLBACK_ENABLED=true                # Keep true until all orgs migrated

# ─── Twilio [REQUIRED for messaging/voice] ───────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token           # Used for webhook HMAC validation
TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Stripe [REQUIRED for billing] ───────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...                    # From Stripe dashboard webhook settings
STRIPE_PRICE_ID=price_...                          # Tier 1 monthly price ID
STRIPE_PRICE_ID_TIER2=price_...                    # Tier 2 monthly price ID
STRIPE_PRICE_ID_STORAGE_10GB=price_...             # Storage add-on 10GB
STRIPE_PRICE_ID_STORAGE_25GB=price_...             # Storage add-on 25GB

# ─── AI / LLM ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...                       # Receipt OCR + voice summarizer
GROQ_API_KEY=gsk_...                               # Lead intent scoring + Dealer Brief (fast inference)
GROQ_API_KEY_2=gsk_...                             # Fallback Groq key
DAILY_INTELLIGENCE_GENERATE_BRIEF=false            # Set true to enable nightly LLM briefing generation (adds ~$0.10/org/day)
PERPLEXITY_API_KEY=pplx-...                        # Market intelligence pricing

# ─── Retell AI (voice agent) ─────────────────────────────────────────────────
RETELL_API_KEY=your-retell-api-key
RETELL_WEBHOOK_SECRET=your-retell-webhook-secret   # HMAC-SHA256 webhook validation

# ─── VAPI (optional voice provider) ─────────────────────────────────────────
VAPI_WEBHOOK_SECRET=your-vapi-webhook-secret

# ─── Google / Gmail ───────────────────────────────────────────────────────────
GMAIL_CLIENT_ID=your-google-oauth-client-id
GMAIL_CLIENT_SECRET=your-google-oauth-client-secret
GMAIL_PUBSUB_TOPIC=projects/your-project/topics/gmail-push  # Gmail watch topic used by users.watch
GMAIL_PUBSUB_SERVICE_ACCOUNT_EMAIL=gmail-api-push@system.gserviceaccount.com  # Verify Google Pub/Sub push identity
GOOGLE_TTS_API_KEY=your-google-tts-api-key         # Text-to-speech for video narration

# ─── Browser Push Notifications (optional) ───────────────────────────────────
# Generate VAPID keys with: npx web-push generate-vapid-keys
# NEXT_PUBLIC_VAPID_PUBLIC_KEY must match VAPID_PUBLIC_KEY exactly.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@dealerwyze.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
# Dealer Success Inbox two-way email (optional — outbound still works without these)
RESEND_INBOUND_SECRET=          # Webhook signing secret from Resend dashboard (HMAC-SHA256 validation)
RESEND_REPLY_DOMAIN=            # e.g. reply.dealerwyze.com — inbound routing domain for reply+{threadId}@

# ─── Telegram (optional — admin alerts) ──────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id
TELEGRAM_WEBHOOK_SECRET=your-telegram-webhook-secret
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=YourBotUsername

# ─── Platform owner notifications ────────────────────────────────────────────
# Email address to notify on new signups, stale dealers, and at-risk orgs
PLATFORM_OWNER_EMAIL=support@dealerwyze.com

# ─── Market Intelligence ──────────────────────────────────────────────────────
MARKETCHECK_API_KEY=your-marketcheck-api-key       # Vehicle market data

# ─── Video / Remotion Lambda ──────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_REGION=us-east-1
REMOTION_SERVE_URL=https://remotionlambda-xxx.s3.amazonaws.com/sites/dealerwyze-vehicles/index.html
REMOTION_LAMBDA_FUNCTION_NAME=remotion-render-4-0-441-mem2048mb-disk2048mb-300sec
REMOTION_LAMBDA_AWS_REGION=us-east-1
RENDER_WEBHOOK_SECRET=your-render-webhook-secret   # Remotion Lambda webhook HMAC

# ─── Cloudflare R2 (video storage) ───────────────────────────────────────────
R2_ACCOUNT_ID=your-r2-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_VIDEOS=dealerwyze-videos
R2_VIDEOS_PUBLIC_URL=https://videos.dealerwyze.com

# ─── Social Media OAuth ───────────────────────────────────────────────────────
SOCIAL_OAUTH_STATE_SECRET=your-oauth-state-secret  # Signs OAuth state params
META_APP_ID=your-meta-app-id                       # Facebook/Instagram
META_APP_SECRET=your-meta-app-secret
INSTAGRAM_APP_ID=your-instagram-app-id
INSTAGRAM_APP_SECRET=your-instagram-app-secret
YOUTUBE_CLIENT_ID=your-youtube-client-id
YOUTUBE_CLIENT_SECRET=your-youtube-client-secret
# TikTok — use sandbox keys for dev, production keys for prod
TIKTOK_CLIENT_KEY=your-tiktok-client-key
TIKTOK_CLIENT_SECRET=your-tiktok-client-secret

# ─── Content MCP (local Cowork integration) ──────────────────────────────────
# Allows the local MCP server to call /api/content/* endpoints without a user session.
# Generate with: openssl rand -hex 32
CONTENT_MCP_TOKEN=your-content-mcp-token
CONTENT_MCP_ORG_ID=your-org-uuid                   # The org to scope MCP content renders to

# ─── Multi-tenant identifiers ─────────────────────────────────────────────────
APOLLO_ORG_ID=your-apollo-auto-org-uuid            # Tim's test tenant org ID

# ─── Integrations ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_INTERVO_WIDGET_ID=your-intervo-widget-id  # Live chat widget on landing page
UNSUBSCRIBE_SECRET=generate-with-openssl-rand-hex-32  # Required. Signs unsubscribe links in emails.

# ─── Google Ads (optional — conversion tracking + remarketing) ───────────────
# Find these in Google Ads: Tools > Conversions > your conversion action > Tag setup
NEXT_PUBLIC_GOOGLE_ADS_ID=AW-XXXXXXXXXX              # Google Ads account tag (e.g. AW-123456789)
NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_LABEL=XXXXXXXXXXXX # Conversion action label (e.g. AbCdEfGhIjK)

# ─── Sentry (optional — error tracking) ──────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=https://xxx@sentry.io/xxx
SENTRY_AUTH_TOKEN=your-sentry-auth-token
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=your-sentry-project

# ─── PostHog (optional — admin adoption analytics) ────────────────────────────
# Client-side key (safe to expose — starts with phc_)
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# Server-side query API key — NEVER expose to client (starts with phx_)
POSTHOG_PERSONAL_API_KEY=phx_xxxxxxxxxxxxxxxxxxxx
POSTHOG_PROJECT_ID=12345

# ─── Axiom (optional — structured log aggregation via Vercel log drain) ───────
# Set up log drain in Vercel dashboard → Integrations → Axiom
# These are NOT used directly in code — Axiom pulls logs via drain; here for reference.
AXIOM_DATASET=dealerwyze-prod                      # Axiom dataset name
AXIOM_TOKEN=your-axiom-api-token                   # Axiom ingest token (set in Vercel drain UI)

# ─── Cloudflare R2 (database backups) ─────────────────────────────────────────
# Separate bucket from video R2. Uses same account token or a dedicated backup token.
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com  # Get from R2 dashboard → Account ID
R2_BUCKET_NAME=dealerwyze-backups
# R2_ACCESS_KEY_ID and R2_SECRET_ACCESS_KEY — reuse values from the video R2 block above
# (or create a separate token scoped to the backups bucket only)
# BACKUP_ENCRYPTION_KEY — AES-256 key for pg_dump encryption.
#   Generate: openssl rand -hex 32
#   Store ONLY as a GitHub Actions secret (BACKUP_ENCRYPTION_KEY). Never put it in Vercel.

# ─── Vercel (set automatically by Vercel, do not set manually) ───────────────
# VERCEL_OIDC_TOKEN — injected by Vercel runtime for OIDC verification
#In Google Ads: Tools > Conversions > create a "Sign up" conversion action → get your AW-XXXXXXXXXX tag ID and conversion label
#Add both to Vercel env vars: NEXT_PUBLIC_GOOGLE_ADS_ID and NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_LABEL

# ─── RealtyWyze Multi-Brand ──────────────────────────────────────────────────
# Domain identifiers used by resolveVertical() in proxy.ts
DEALERWYZE_DOMAIN=dealerwyze.com
REALTYWYZE_DOMAIN=realtywyze.us

# Separate PostHog project for RealtyWyze (clean analytics per brand)
# Get key from PostHog dashboard — create a new project named "RealtyWyze"
NEXT_PUBLIC_POSTHOG_KEY_REALTY=phc_

# RE Listing Intelligence (Phase 7 — RealtyWyze)
APIFY_API_TOKEN=apify_api_...       # Apify account token for Zillow/Redfin scraping (~$0.002/import)
RENTCAST_API_KEY=your-rentcast-key  # RentCast property data API ($74/mo plan)

# RE Showings — Cal.com webhook (Phase 8 — RealtyWyze)
# Set this to the signing secret from Cal.com > Webhooks > [your webhook] > Signing Secret
# Required only if using Cal.com self-serve booking (SHOW-07)
CALCOM_WEBHOOK_SECRET=your_calcom_webhook_secret_here
